# --- CORS ---
CORS_ORIGINS=https://codena.sn,https://www.codena.sn

# --- OTP ---
OTP_TTL_SECONDS=300
# EXPOSE_OTP : renvoyer le code dans la réponse API.
# Laisser vide = auto (démo si aucun SMS configuré). Forcer avec 0 ou 1.
# EXPOSE_OTP=0

# --- SMS réel (optionnel, Orange SMS API - Sénégal) ---
# Renseigner CLIENT_ID + CLIENT_SECRET pour activer l'envoi SMS réel.
# Identifiants dans la section "MyApps" de developer.orange.com
# ORANGE_CLIENT_ID=xxxxxxxxxxxxxxxx
# ORANGE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# senderAddress Sénégal (valeur par défaut, à ne changer que si Orange te l'indique)
# ORANGE_SENDER_ADDRESS=tel:+2210000
# Sender name personnalisé, ≤ 11 caractères, doit être white-listé par Orange (optionnel)
# ORANGE_SENDER_NAME=Codena
